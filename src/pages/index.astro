---
import { getCollection } from "astro:content";

import { withBase } from "../lib/paths";
import { formatPostDate, getPublishedPosts } from "../lib/posts";
import SiteLayout from "../layouts/SiteLayout.astro";
import { siteConfig } from "../site-config";

const entries = await getCollection("posts");
const posts = getPublishedPosts(
  entries.map((entry) => ({
    id: entry.id,
    slug: entry.id,
    data: entry.data,
  })),
);
const baseUrl = import.meta.env.BASE_URL;
---

<SiteLayout title={siteConfig.title} description={siteConfig.description} activePath="/">
  <section class="page-intro">
    <p class="page-intro__label">Пишу</p>
  </section>

  {
    posts.length > 0 ? (
        <ul class="post-list" aria-label="Список постов">
          {posts.map((post, index) => (
            <li class="post-list__item reveal" style={`--stagger-index:${index};`}>
              <a class="post-list__link" href={withBase(`/posts/${post.slug}`, baseUrl)}>
              <span class="post-list__title">{post.data.title}</span>
              <time class="post-list__date" datetime={post.data.date.toISOString()}>
                {formatPostDate(post.data.date)}
              </time>
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <div class="empty-state reveal">
        <p>Пока здесь нет постов. Добавьте `.md` файл в папку `posts/`, и он появится в списке.</p>
      </div>
    )
  }
</SiteLayout>
