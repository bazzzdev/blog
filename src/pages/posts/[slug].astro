---
import { getCollection, render } from "astro:content";

import { withBase } from "../../lib/paths";
import { formatPostDate, getAdjacentPosts, getPublishedPosts } from "../../lib/posts";
import SiteLayout from "../../layouts/SiteLayout.astro";

export async function getStaticPaths() {
  const entries = await getCollection("posts");
  const posts = getPublishedPosts(
    entries.map((entry) => ({
      id: entry.id,
      slug: entry.id,
      data: entry.data,
    })),
  );

  return posts.map((post) => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;

const entries = await getCollection("posts");
const posts = getPublishedPosts(
  entries.map((entry) => ({
    id: entry.id,
    slug: entry.id,
    data: entry.data,
  })),
);
const post = entries.find((entry) => entry.id === slug && !entry.data.draft);

if (!post) {
  return Astro.redirect(withBase("/", import.meta.env.BASE_URL));
}

const { previousPost, nextPost } = getAdjacentPosts(posts, post.id);
const { Content } = await render(post);
---

<SiteLayout title={post.data.title} description={post.data.description} activePath="/">
  <section class="page-intro">
    <p class="page-intro__label">{formatPostDate(post.data.date)}</p>
  </section>

  <article class="article reveal">
    <div class="article__body">
      <Content />
    </div>
  </article>

  <nav class="article-nav reveal" aria-label="Навигация по публикациям">
    {
      previousPost ? (
        <a class="article-nav__link article-nav__link--previous" href={withBase(`/posts/${previousPost.slug}/`, import.meta.env.BASE_URL)}>
          <span class="article-nav__direction" aria-hidden="true">←</span>
          <span class="article-nav__title">{previousPost.data.title}</span>
        </a>
      ) : (
        <div class="article-nav__empty" aria-hidden="true"></div>
      )
    }
    {
      nextPost ? (
        <a class="article-nav__link article-nav__link--next" href={withBase(`/posts/${nextPost.slug}/`, import.meta.env.BASE_URL)}>
          <span class="article-nav__title">{nextPost.data.title}</span>
          <span class="article-nav__direction" aria-hidden="true">→</span>
        </a>
      ) : (
        <div class="article-nav__empty" aria-hidden="true"></div>
      )
    }
  </nav>
</SiteLayout>
